generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int           @id @default(autoincrement())
  name                String
  email               String        @unique
  passwordHash        String        @map("password_hash")
  monthlySalary       Decimal       @db.Decimal(12, 2) @map("monthly_salary")
  incomeCurrencyCode  String        @default("USD") @map("income_currency_code")
  salaryPaymentMethod String        @map("salary_payment_method")
  salaryCashAmount    Decimal       @default(0) @db.Decimal(12, 2) @map("salary_cash_amount")
  salaryCardAmount    Decimal       @default(0) @db.Decimal(12, 2) @map("salary_card_amount")
  salaryCashAllocationPct Int       @default(0) @map("salary_cash_allocation_pct")
  salaryCardAllocationPct Int       @default(100) @map("salary_card_allocation_pct")
  incomeDayOfMonth    Int           @default(1) @map("income_day_of_month")
  monthlySavingsTarget Decimal      @default(0) @db.Decimal(12, 2) @map("monthly_savings_target")
  partnerId           Int?          @unique @map("partner_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  transactions        Transaction[]
  savingsEntries      SavingsEntry[]
  passwordResetTokens PasswordResetToken[]
  sentCoupleInvites   CoupleInvite[] @relation("CoupleInviteSender")
  receivedCoupleInvites CoupleInvite[] @relation("CoupleInviteRecipient")
  sentActivityNotifications ActivityNotification[] @relation("ActivityNotificationActor")
  receivedActivityNotifications ActivityNotification[] @relation("ActivityNotificationRecipient")
  partner             User?         @relation("UserPartner", fields: [partnerId], references: [id])
  partneredBy         User?         @relation("UserPartner")
  coupleAsUserOne     Couple[]      @relation("CoupleUserOne")
  coupleAsUserTwo     Couple[]      @relation("CoupleUserTwo")

  @@map("users")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Couple {
  id        Int      @id @default(autoincrement())
  userOneId Int      @unique @map("user_one_id")
  userTwoId Int      @unique @map("user_two_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userOne   User     @relation("CoupleUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo   User     @relation("CoupleUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)
  coachProfile CoupleCoachProfile?
  savingsGoals SavingsGoal[]

  @@map("couples")
}

model CoupleCoachProfile {
  id                 Int      @id @default(autoincrement())
  coupleId           Int      @unique @map("couple_id")
  primaryGoal        String   @map("primary_goal")
  goalHorizon        String   @map("goal_horizon")
  biggestMoneyStress String   @map("biggest_money_stress")
  hardestCategory    String   @map("hardest_category")
  conflictTrigger    String   @map("conflict_trigger")
  coachingFocus      String   @map("coaching_focus")
  notes              String?  @map("notes")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  couple             Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@map("couple_coach_profiles")
}

model CoupleInvite {
  id          Int      @id @default(autoincrement())
  senderId    Int      @map("sender_id")
  recipientId Int      @map("recipient_id")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  respondedAt DateTime? @map("responded_at")
  sender      User     @relation("CoupleInviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("CoupleInviteRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, status, createdAt])
  @@index([senderId, status, createdAt])
  @@map("couple_invites")
}

model ActivityNotification {
  id          Int      @id @default(autoincrement())
  recipientId Int      @map("recipient_id")
  actorId     Int      @map("actor_id")
  type        String
  title       String
  body        String
  createdAt   DateTime @default(now()) @map("created_at")
  readAt      DateTime? @map("read_at")
  recipient   User     @relation("ActivityNotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User     @relation("ActivityNotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@map("activity_notifications")
}

model Transaction {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  amount        Decimal  @db.Decimal(12, 2)
  currencyCode  String   @default("USD") @map("currency_code")
  description   String
  category      String
  type          String
  paymentMethod String   @map("payment_method")
  date          DateTime @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("transactions")
}

model SavingsEntry {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  savingsGoalId Int? @map("savings_goal_id")
  amount    Decimal  @db.Decimal(12, 2)
  currencyCode String @default("USD") @map("currency_code")
  note      String
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoal SavingsGoal? @relation(fields: [savingsGoalId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([savingsGoalId, date])
  @@map("savings_entries")
}

model SavingsGoal {
  id           Int       @id @default(autoincrement())
  coupleId     Int       @map("couple_id")
  title        String
  targetAmount Decimal   @db.Decimal(12, 2) @map("target_amount")
  currencyCode String    @default("USD") @map("currency_code")
  targetDate   DateTime? @db.Date @map("target_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  couple       Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  savingsEntries SavingsEntry[]

  @@index([coupleId, createdAt])
  @@map("savings_goals")
}
