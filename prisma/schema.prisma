generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int           @id @default(autoincrement())
  name                String
  email               String        @unique
  passwordHash        String        @map("password_hash")
  monthlySalary       Decimal       @db.Decimal(12, 2) @map("monthly_salary")
  incomeCurrencyCode  String        @default("USD") @map("income_currency_code")
  salaryPaymentMethod String        @map("salary_payment_method")
  salaryCashAmount    Decimal       @default(0) @db.Decimal(12, 2) @map("salary_cash_amount")
  salaryCardAmount    Decimal       @default(0) @db.Decimal(12, 2) @map("salary_card_amount")
  salaryCashAllocationPct Int       @default(0) @map("salary_cash_allocation_pct")
  salaryCardAllocationPct Int       @default(100) @map("salary_card_allocation_pct")
  incomeDayOfMonth    Int           @default(1) @map("income_day_of_month")
  monthlySavingsTarget Decimal      @default(0) @db.Decimal(12, 2) @map("monthly_savings_target")
  partnerId           Int?          @unique @map("partner_id")
  subscriptionStatus  String        @default("free") @map("subscription_status")
  subscriptionExpiresAt DateTime?   @map("subscription_expires_at")
  subscriptionProvider String?      @map("subscription_provider")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  transactions        Transaction[]
  savingsEntries      SavingsEntry[]
  passwordResetTokens PasswordResetToken[]
  sentCoupleInvites   CoupleInvite[] @relation("CoupleInviteSender")
  receivedCoupleInvites CoupleInvite[] @relation("CoupleInviteRecipient")
  sentActivityNotifications ActivityNotification[] @relation("ActivityNotificationActor")
  receivedActivityNotifications ActivityNotification[] @relation("ActivityNotificationRecipient")
  recurringBills      RecurringBill[]
  savingsGoals        SavingsGoal[]
  pushDevices         PushDevice[]
  coachProfile        CoupleCoachProfile?
  partner             User?         @relation("UserPartner", fields: [partnerId], references: [id])
  partneredBy         User?         @relation("UserPartner")
  coupleAsUserOne     Couple[]      @relation("CoupleUserOne")
  coupleAsUserTwo     Couple[]      @relation("CoupleUserTwo")
  couponRedemptions   CouponRedemption[]
  budgetPlans         BudgetPlan[]

  @@map("users")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Couple {
  id                Int       @id @default(autoincrement())
  userOneId         Int       @unique @map("user_one_id")
  userTwoId         Int       @unique @map("user_two_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  insightsCacheJson String?   @map("insights_cache_json") @db.Text
  insightsCachedAt  DateTime? @map("insights_cached_at")
  userOne           User      @relation("CoupleUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo           User      @relation("CoupleUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)
  coachProfile      CoupleCoachProfile?
  mmkMonthlyRates   CoupleMmkMonthlyRate[]
  savingsGoals      SavingsGoal[]
  recurringBills    RecurringBill[]
  householdRules    HouseholdRule[]
  budgetPlans       BudgetPlan[]

  @@map("couples")
}

model CoupleMmkMonthlyRate {
  id         Int      @id @default(autoincrement())
  coupleId    Int      @map("couple_id")
  year        Int
  month       Int
  rateSource  String   @map("rate_source")
  rate        Decimal  @db.Decimal(14, 6)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@unique([coupleId, year, month])
  @@map("couple_mmk_monthly_rates")
}

model CoupleCoachProfile {
  id                      Int      @id @default(autoincrement())
  coupleId                Int?     @unique @map("couple_id")
  userId                  Int?     @unique @map("user_id")
  primaryGoal             String   @map("primary_goal")
  goalHorizon             String   @map("goal_horizon")
  biggestMoneyStress      String   @map("biggest_money_stress")
  hardestCategory         String   @map("hardest_category")
  conflictTrigger         String   @map("conflict_trigger")
  coachingFocus           String   @map("coaching_focus")
  notes                   String?  @map("notes")
  monthlyBudgetTarget     Decimal? @map("monthly_budget_target") @db.Decimal(14, 2)
  paySchedule             String?  @map("pay_schedule")
  personalAllowance       Decimal? @map("personal_allowance") @db.Decimal(14, 2)
  totalDebtAmount         Decimal? @map("total_debt_amount") @db.Decimal(14, 2)
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  couple                  Couple?  @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user                    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("couple_coach_profiles")
}

model CoupleInvite {
  id          Int      @id @default(autoincrement())
  senderId    Int      @map("sender_id")
  recipientId Int      @map("recipient_id")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  respondedAt DateTime? @map("responded_at")
  sender      User     @relation("CoupleInviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("CoupleInviteRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, status, createdAt])
  @@index([senderId, status, createdAt])
  @@map("couple_invites")
}

model ActivityNotification {
  id          Int      @id @default(autoincrement())
  recipientId Int      @map("recipient_id")
  actorId     Int      @map("actor_id")
  type        String
  title       String
  body        String
  createdAt   DateTime @default(now()) @map("created_at")
  readAt      DateTime? @map("read_at")
  recipient   User     @relation("ActivityNotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User     @relation("ActivityNotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@map("activity_notifications")
}

model PushDevice {
  id         Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  platform    String
  token       String   @unique
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@map("push_devices")
}

model Transaction {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  recurringBillId Int?   @map("recurring_bill_id")
  autoCreated   Boolean  @default(false) @map("auto_created")
  amount        Decimal  @db.Decimal(12, 2)
  currencyCode  String   @default("USD") @map("currency_code")
  convertedAmount Decimal? @db.Decimal(14, 4) @map("converted_amount")
  convertedCurrencyCode String? @map("converted_currency_code")
  conversionAnchorAmount Decimal? @db.Decimal(14, 4) @map("conversion_anchor_amount")
  conversionAnchorCurrencyCode String? @map("conversion_anchor_currency_code")
  exchangeRateUsed Decimal? @db.Decimal(14, 6) @map("exchange_rate_used")
  exchangeRateSource String? @map("exchange_rate_source")
  description   String
  category      String
  type          String
  paymentMethod String   @map("payment_method")
  date          DateTime @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringBill RecurringBill? @relation(fields: [recurringBillId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([recurringBillId, date])
  @@map("transactions")
}

model SavingsEntry {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  savingsGoalId Int? @map("savings_goal_id")
  amount    Decimal  @db.Decimal(12, 2)
  currencyCode String @default("USD") @map("currency_code")
  note      String
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoal SavingsGoal? @relation(fields: [savingsGoalId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([savingsGoalId, date])
  @@map("savings_entries")
}

model SavingsGoal {
  id           Int       @id @default(autoincrement())
  coupleId     Int?      @map("couple_id")
  userId       Int?      @map("user_id")
  title        String
  targetAmount Decimal   @db.Decimal(12, 2) @map("target_amount")
  currencyCode String    @default("USD") @map("currency_code")
  targetDate   DateTime? @db.Date @map("target_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  couple       Couple?   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsEntries SavingsEntry[]

  @@index([coupleId, createdAt])
  @@index([userId, createdAt])
  @@map("savings_goals")
}

model RecurringBill {
  id            Int      @id @default(autoincrement())
  coupleId      Int      @map("couple_id")
  userId        Int      @map("user_id")
  title         String
  amount        Decimal  @db.Decimal(12, 2)
  currencyCode  String   @default("USD") @map("currency_code")
  category      String
  paymentMethod String   @map("payment_method")
  dayOfMonth    Int      @map("day_of_month")
  notes         String?  @map("notes")
  isActive      Boolean  @default(true) @map("is_active")
  autoCreate    Boolean  @default(true) @map("auto_create")
  startDate     DateTime @db.Date @map("start_date")
  endDate       DateTime? @db.Date @map("end_date")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  couple        Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@index([coupleId, isActive, dayOfMonth])
  @@index([userId, createdAt])
  @@map("recurring_bills")
}

model HouseholdRule {
  id              Int      @id @default(autoincrement())
  coupleId        Int      @map("couple_id")
  title           String
  details         String
  thresholdAmount Decimal? @db.Decimal(12, 2) @map("threshold_amount")
  currencyCode    String?  @map("currency_code")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  couple          Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId, isActive, createdAt])
  @@map("household_rules")
}

model CouponCode {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  type         String   // "permanent" | "days"
  durationDays Int?     @map("duration_days")
  maxUses      Int?     @map("max_uses")
  usedCount    Int      @default(0) @map("used_count")
  isActive     Boolean  @default(true) @map("is_active")
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")
  redemptions  CouponRedemption[]

  @@map("coupon_codes")
}

model CouponRedemption {
  id           Int        @id @default(autoincrement())
  userId       Int        @map("user_id")
  couponCodeId Int        @map("coupon_code_id")
  redeemedAt   DateTime   @default(now()) @map("redeemed_at")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon       CouponCode @relation(fields: [couponCodeId], references: [id])

  @@unique([userId, couponCodeId])
  @@map("coupon_redemptions")
}

model BudgetPlan {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  coupleId     Int?     @map("couple_id")
  name         String
  startMonth   String   @map("start_month")
  endMonth     String   @map("end_month")
  planJson     String   @map("plan_json") @db.Text
  goalAmount   Decimal? @db.Decimal(14, 2) @map("goal_amount")
  goalCurrency String?  @map("goal_currency")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple       Couple?  @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@map("budget_plans")
}
