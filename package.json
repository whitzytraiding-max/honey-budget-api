  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node node_modules/prisma/build/index.js migrate deploy; node src/server.js",
    "start:lan": "HOST=0.0.0.0 node src/server.js",
    "brand:assets": "python3 scripts/generate_brand_assets.py",
    "test": "vitest run",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "prisma:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate resolve --rolled-back 20260417120000_add_google_auth || true && node ./node_modules/prisma/build/index.js migrate deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@google/generative-ai": "^0.24.1",
